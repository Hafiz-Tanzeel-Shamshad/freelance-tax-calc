# ────────────────────────────────────────────
# .htaccess — FreelanceTaxCalc
# For Apache servers. If using Nginx, convert
# these rules to your server block configuration.
# ────────────────────────────────────────────

RewriteEngine On

# ── Force HTTPS ──
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ── Redirect www to non-www ──
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# ── Redirect .html URLs to clean URLs (301) ──
RewriteCond %{THE_REQUEST} \.html[/\s?] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L,NE]

# ── Clean URLs: internally rewrite to .html file ──
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# ── Directory clean URLs: ensure trailing slash for dirs ──
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*[^/])$ /$1/ [R=301,L]

# ── Redirect old flat URLs to new /tools/ directory ──
RewriteRule ^quarterly-tax-calculator\.html$ /tools/quarterly-tax-calculator [R=301,L]
RewriteRule ^gig-deduction-finder\.html$ /tools/gig-deduction-finder [R=301,L]
RewriteRule ^first-paycheck-calculator\.html$ /tools/first-paycheck-calculator [R=301,L]
RewriteRule ^side-hustle-tax-estimator\.html$ /tools/side-hustle-tax-estimator [R=301,L]
RewriteRule ^finance-app-recommender\.html$ /tools/finance-app-recommender [R=301,L]
RewriteRule ^digital-nomad-tax-calculator\.html$ /tools/digital-nomad-tax-calculator [R=301,L]
RewriteRule ^1099-vs-w2-calculator\.html$ /tools/1099-vs-w2-calculator [R=301,L]
RewriteRule ^rate-calculator-debt-planner\.html$ /tools/rate-calculator-debt-planner [R=301,L]
RewriteRule ^freelance-hourly-rate-calculator\.html$ /tools/freelance-hourly-rate-calculator [R=301,L]
RewriteRule ^retirement-calculator\.html$ /tools/retirement-calculator [R=301,L]
RewriteRule ^budget-invoice-calculators\.html$ /tools/budget-invoice-calculators [R=301,L]
RewriteRule ^about\.html$ /legal/about [R=301,L]
RewriteRule ^privacy-policy\.html$ /legal/privacy-policy [R=301,L]
RewriteRule ^terms\.html$ /legal/terms [R=301,L]
RewriteRule ^legal/contact\.html$ /contact [R=301,L]
RewriteRule ^guides\.html$ /guides/ [R=301,L]
RewriteRule ^deductions/doordash\.html$ /deductions/doordash [R=301,L]
RewriteRule ^deductions/uber\.html$ /deductions/uber [R=301,L]
RewriteRule ^deductions/etsy\.html$ /deductions/etsy [R=301,L]
RewriteRule ^deductions/airbnb\.html$ /deductions/airbnb [R=301,L]
RewriteRule ^deductions/fiverr\.html$ /deductions/fiverr [R=301,L]
RewriteRule ^deductions/instacart\.html$ /deductions/instacart [R=301,L]
RewriteRule ^digital-nomad-tax/portugal\.html$ /digital-nomad-tax/portugal [R=301,L]
RewriteRule ^digital-nomad-tax/spain\.html$ /digital-nomad-tax/spain [R=301,L]
RewriteRule ^digital-nomad-tax/thailand\.html$ /digital-nomad-tax/thailand [R=301,L]
RewriteRule ^digital-nomad-tax/estonia\.html$ /digital-nomad-tax/estonia [R=301,L]
RewriteRule ^digital-nomad-tax/mexico\.html$ /digital-nomad-tax/mexico [R=301,L]

# ── Custom 404 page ──
ErrorDocument 404 /404.html

# ── Security headers ──
<IfModule mod_headers.c>
  # Prevent MIME type sniffing
  Header set X-Content-Type-Options "nosniff"

  # Enable XSS filter in older browsers
  Header set X-XSS-Protection "1; mode=block"

  # Prevent clickjacking
  Header set X-Frame-Options "SAMEORIGIN"

  # Referrer policy
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # HSTS (HTTPS Strict Transport Security) — enable after confirming SSL works
  # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ── Cache static assets ──
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# ── Compress text files ──
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
