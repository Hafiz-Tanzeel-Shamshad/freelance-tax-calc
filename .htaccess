# --- .htaccess --- FreelanceTaxCalc ---

RewriteEngine On

# --- Force HTTPS ---
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# --- Redirect www to non-www ---
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# --- Ensure trailing slash for directories ---
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*[^/])$ /$1/ [R=301,L]

# --- Redirect /tools/quarterly-tax-calculator to .html file (before trailing-slash rule) ---
RewriteRule ^tools/quarterly\-tax\-calculator$ /tools/quarterly-tax-calculator.html [R=301,L]
RewriteRule ^tools/quarterly\-tax\-calculator/$ /tools/quarterly-tax-calculator.html [R=301,L]

# --- Redirect clean URLs to .html (server needs explicit .html extension) ---
RewriteRule ^tools/quarterly\-tax\-calculator/north\-carolina$ /tools/quarterly-tax-calculator/north-carolina.html [R=301,L]
RewriteRule ^north\-carolina\.html$ /tools/quarterly-tax-calculator/north-carolina.html [R=301,L]
